# Supabase Configuration
# Get these values from your Supabase project settings
# https://app.supabase.com/project/YOUR_PROJECT_ID/settings/api

# Public/Client-side variables (safe to expose)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGc...your_anon_key

# Server-side variables (keep secret, never expose to frontend)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=eyJhbGc...your_anon_key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...your_service_role_key

# Lovable Configuration (if using Lovable.dev)
LOVABLE_PROJECT_ID=your_project_id
LOVABLE_API_KEY=your_api_key
